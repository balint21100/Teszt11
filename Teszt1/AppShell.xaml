<Shell
    x:Class="Teszt1.AppShell"
    xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
    xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
    xmlns:frontend="clr-namespace:Teszt1.Frontend"
    xmlns:root="clr-namespace:Teszt1"
    Shell.FlyoutBehavior="Flyout"
    Title="Teszt1">


    <FlyoutItem Title="Étkezés">
        <!-- Itt a root:MainPage-et használjuk, mert a MainPage a Teszt1 névtérben van -->
        <ShellContent ContentTemplate="{DataTemplate root:MainPage}" Route="MainPage" />
    </FlyoutItem>

    <FlyoutItem Title="Edzésterv">
        <ShellContent ContentTemplate="{DataTemplate frontend:EdzesPage}" Route="EdzesPage" />
    </FlyoutItem>

    <FlyoutItem Title="EÜ Adatok">
        <ShellContent ContentTemplate="{DataTemplate frontend:EuAdatokPage}" Route="EuAdatokPage" />
    </FlyoutItem>

    <FlyoutItem Title="Barátaim">
        <ShellContent ContentTemplate="{DataTemplate frontend:BaratokPage}" Route="BaratokPage" />
    </FlyoutItem>

</Shell>