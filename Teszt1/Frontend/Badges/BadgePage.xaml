<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             xmlns:local="clr-namespace:Teszt1.Frontend.Badges" 
             x:Class="Teszt1.Frontend.Badges.BadgePage"
             x:DataType="local:BadgePageViewModel"
             Title="Badge-ek"
             BackgroundColor="#121212">

    <ContentPage.BindingContext>
        <local:BadgePageViewModel />
    </ContentPage.BindingContext>

    <Grid>
        <!-- Háttérkép -->
        <Image Source="hatterkep.png" Aspect="AspectFill" Opacity="0.5"/>

        <ScrollView Padding="15">
            <Border BackgroundColor="#CC000000" Padding="15">
                <Border.StrokeShape>
                    <RoundRectangle CornerRadius="20" />
                </Border.StrokeShape>
                <Border.Stroke>
                    <SolidColorBrush Color="#444444" />
                </Border.Stroke>

                <VerticalStackLayout Spacing="20">

                    <!-- Cím -->
                    <Label Text="Badge-ek" FontSize="28" FontAttributes="Bold" TextColor="White" HorizontalOptions="Center" Margin="0,10"/>
                    <Label Text="Az eddig megszerzett kitüntetéseid és eredményeid:" TextColor="LightGray" FontSize="14" HorizontalOptions="Center" Margin="0,-10,0,10"/>

                    <!-- Jelvények listája -->
                    <CollectionView ItemsSource="{Binding BadgeLista}">
                        <CollectionView.ItemTemplate>
                            <DataTemplate x:DataType="local:BadgeItem">

                                <Border BackgroundColor="#20FFFFFF" Padding="12" Margin="0,0,0,12" StrokeThickness="0">
                                    <Border.StrokeShape>
                                        <RoundRectangle CornerRadius="15" />
                                    </Border.StrokeShape>
                                    <Grid ColumnDefinitions="70, *">

                                        <!-- SAJÁT PNG KÉP (Bal oldal) -->
                                        <Image Grid.Column="0" 
                                               Source="{Binding KepHivatkozas}" 
                                               Opacity="{Binding KepAtlatszosag}"
                                               HeightRequest="55" 
                                               WidthRequest="55" 
                                               Aspect="AspectFit"
                                               HorizontalOptions="Center" 
                                               VerticalOptions="Center" />

                                        <!-- Szöveg (Jobb oldal) - a színük változik a megszerzéstől függően -->
                                        <VerticalStackLayout Grid.Column="1" VerticalOptions="Center" Spacing="2" Margin="10,0,0,0">
                                            <Label Text="{Binding Nev}" TextColor="{Binding CimSzin}" FontSize="16" FontAttributes="Bold"/>
                                            <Label Text="{Binding Leiras}" TextColor="{Binding LeirasSzin}" FontSize="12" LineBreakMode="WordWrap"/>
                                        </VerticalStackLayout>

                                    </Grid>
                                </Border>

                            </DataTemplate>
                        </CollectionView.ItemTemplate>
                    </CollectionView>

                </VerticalStackLayout>
            </Border>
        </ScrollView>
    </Grid>
</ContentPage>