<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             x:Class="Teszt1.Frontend.EuAdatokPage"
             xmlns:local="clr-namespace:Teszt1.Frontend"
             x:DataType="local:EuAdatokPageViewModel"
             Title="EÜ Adatok"
             BackgroundColor="Transparent">

    <Grid>
        <Image Source="hatterkep.png" Aspect="AspectFill" HorizontalOptions="FillAndExpand" VerticalOptions="FillAndExpand"/>

        <ScrollView Padding="20">
            <Border BackgroundColor="#B0000000" Stroke="Gray" StrokeThickness="1" StrokeShape="RoundRectangle 20" Padding="20">
                <VerticalStackLayout Spacing="20">

                    <Label Text="Egészségadatok" FontSize="28" FontAttributes="Bold" HorizontalOptions="Center" TextColor="White" Margin="0,0,0,10"/>

                    <Border WidthRequest="120" HeightRequest="120" StrokeShape="RoundRectangle 60" HorizontalOptions="Center" Stroke="#6200EE" StrokeThickness="3">
                        <Image Source="dotnet_bot.png" Aspect="AspectFill" BackgroundColor="#333" />
                    </Border>

                    <Frame BackgroundColor="#20FFFFFF" CornerRadius="15" Padding="15" BorderColor="Transparent" HasShadow="False">
                        <VerticalStackLayout Spacing="15">

                            <HorizontalStackLayout Spacing="10">
                                <Label Text="Cél:" FontAttributes="Bold" TextColor="LightGray" VerticalOptions="Center"/>
                                <Entry Text="{Binding Cel}" TextColor="White" WidthRequest="200" />
                            </HorizontalStackLayout>

                            <HorizontalStackLayout Spacing="10">
                                <Label Text="Teljesített napok a kihívásból:" TextColor="LightGray" VerticalOptions="Center" />
                                <Label Text="{Binding KihivasProgressz}" FontAttributes="Bold" TextColor="#00E676" FontSize="16" VerticalOptions="Center" />
                            </HorizontalStackLayout>

                            <BoxView HeightRequest="1" Color="#40FFFFFF" Margin="0,5" />

                            <Grid ColumnDefinitions="120, *" RowDefinitions="Auto, Auto, Auto, Auto" RowSpacing="10">
                                <Label Grid.Row="0" Grid.Column="0" Text="Magasság (cm):" TextColor="LightGray" VerticalOptions="Center"/>
                                <Entry Grid.Row="0" Grid.Column="1" Text="{Binding Magassag}" Keyboard="Numeric" TextColor="White"/>

                                <Label Grid.Row="1" Grid.Column="0" Text="Testsúly (kg):" TextColor="LightGray" VerticalOptions="Center"/>
                                <Entry Grid.Row="1" Grid.Column="1" Text="{Binding Testsuly}" Keyboard="Numeric" TextColor="White"/>

                                <Label Grid.Row="2" Grid.Column="0" Text="Vérnyomás:" TextColor="LightGray" VerticalOptions="Center"/>
                                <Entry Grid.Row="2" Grid.Column="1" Text="{Binding Vernyomas}" TextColor="White"/>

                                <Label Grid.Row="3" Grid.Column="0" Text="Lépésszám:" TextColor="LightGray" VerticalOptions="Center"/>
                                <HorizontalStackLayout Grid.Row="3" Grid.Column="1" Spacing="5" VerticalOptions="Center">
                                    <Label Text="{Binding Lepesszam}" TextColor="White" FontAttributes="Bold" />
                                    <Label Text="/" TextColor="Gray" />
                                    <Label Text="{Binding LepesszamCel}" TextColor="Gray" />
                                </HorizontalStackLayout>
                            </Grid>

                            <Label Text="Egyéb adat (pl. cukorbetegség, menstruáció):" TextColor="LightGray" Margin="0,10,0,0"/>
                            <Frame BackgroundColor="#40000000" CornerRadius="10" Padding="0" BorderColor="Transparent" HasShadow="False">
                                <Editor Text="{Binding EgyebAdat}" TextColor="White" HeightRequest="80" BackgroundColor="Transparent" />
                            </Frame>

                        </VerticalStackLayout>
                    </Frame>

                    <Button Text="Mentés" Command="{Binding MentesCommand}" BackgroundColor="#6200EE" TextColor="White" CornerRadius="15" HeightRequest="50" FontAttributes="Bold" Margin="0,10,0,0" />

                </VerticalStackLayout>
            </Border>
        </ScrollView>
    </Grid>
</ContentPage>