<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             xmlns:local="clr-namespace:Teszt1.Frontend.Edzes"
             x:Class="Teszt1.Frontend.Edzes.EdzesPage"
             x:DataType="local:EdzesPageViewModel"
             Title="Edzés"
             BackgroundColor="Transparent">


    <Grid>
        <Image Source="hatterkep.png" Aspect="AspectFill" HorizontalOptions="FillAndExpand" VerticalOptions="FillAndExpand"/>

        <Grid RowDefinitions="*" Padding="20">
            <ScrollView Grid.Row="0" Margin="0,0,0,10">
                <Frame BackgroundColor="#B0000000" CornerRadius="20" Padding="20" BorderColor="Gray">
                    <VerticalStackLayout Spacing="10">
                        <VerticalStackLayout Spacing="5" Margin="0,0,0,15">
                            <Label Text="Heti edzésterv" FontSize="32" FontAttributes="Bold" TextColor="White" HorizontalOptions="Center" />
                            <Label Text="{Binding AktualisHet}" FontSize="15" TextColor="White" FontAttributes="Bold" HorizontalOptions="Center" TextTransform="Lowercase"/>
                        </VerticalStackLayout>

                        <Frame BackgroundColor="Transparent" Padding="5" BorderColor="{Binding HetfoKeret}" CornerRadius="10">
                            <Grid ColumnDefinitions="90, *, 45" ColumnSpacing="10" VerticalOptions="Center">
                                <Label Grid.Column="0" Text="Hétfő" TextColor="White" FontAttributes="Bold" FontSize="18" VerticalOptions="Center"/>
                                <Picker Grid.Column="1" ClassId="Hétfő" SelectedIndexChanged="OnEdzesKivalasztva" 
                                        ItemsSource="{Binding HetfoEdzesek}" SelectedItem="{Binding KivalasztottHetfo}" 
                                        Title="Válassz edzést..." TitleColor="LightGray" TextColor="White" VerticalOptions="Center" />
                                <Button Grid.Column="2" Clicked="OnSzerkesztesKattintva" Text="⚙️" BackgroundColor="#6200EE" TextColor="White" CornerRadius="10" Padding="0" HeightRequest="45" VerticalOptions="Center"/>
                            </Grid>
                        </Frame>
                        <BoxView HeightRequest="1" Color="#40FFFFFF" Margin="0,5"/>

                        <Frame BackgroundColor="Transparent" Padding="5" BorderColor="{Binding KeddKeret}" CornerRadius="10">
                            <Grid ColumnDefinitions="90, *, 45" ColumnSpacing="10" VerticalOptions="Center">
                                <Label Grid.Column="0" Text="Kedd" TextColor="White" FontAttributes="Bold" FontSize="18" VerticalOptions="Center"/>
                                <Picker Grid.Column="1" ClassId="Kedd" SelectedIndexChanged="OnEdzesKivalasztva" 
                                        ItemsSource="{Binding KeddEdzesek}" SelectedItem="{Binding KivalasztottKedd}" 
                                        Title="Válassz edzést..." TitleColor="LightGray" TextColor="White" VerticalOptions="Center" />
                                <Button Grid.Column="2" Clicked="OnSzerkesztesKattintva" Text="⚙️" BackgroundColor="#6200EE" TextColor="White" CornerRadius="10" Padding="0" HeightRequest="45" VerticalOptions="Center"/>
                            </Grid>
                        </Frame>
                        <BoxView HeightRequest="1" Color="#40FFFFFF" Margin="0,5"/>

                        <Frame BackgroundColor="Transparent" Padding="5" BorderColor="{Binding SzerdaKeret}" CornerRadius="10">
                            <Grid ColumnDefinitions="90, *, 45" ColumnSpacing="10" VerticalOptions="Center">
                                <Label Grid.Column="0" Text="Szerda" TextColor="White" FontAttributes="Bold" FontSize="18" VerticalOptions="Center"/>
                                <Picker Grid.Column="1" ClassId="Szerda" SelectedIndexChanged="OnEdzesKivalasztva" 
                                        ItemsSource="{Binding SzerdaEdzesek}" SelectedItem="{Binding KivalasztottSzerda}" 
                                        Title="Válassz edzést..." TitleColor="LightGray" TextColor="White" VerticalOptions="Center" />
                                <Button Grid.Column="2" Clicked="OnSzerkesztesKattintva" Text="⚙️" BackgroundColor="#6200EE" TextColor="White" CornerRadius="10" Padding="0" HeightRequest="45" VerticalOptions="Center"/>
                            </Grid>
                        </Frame>
                        <BoxView HeightRequest="1" Color="#40FFFFFF" Margin="0,5"/>

                        <Frame BackgroundColor="Transparent" Padding="5" BorderColor="{Binding CsutortokKeret}" CornerRadius="10">
                            <Grid ColumnDefinitions="90, *, 45" ColumnSpacing="10" VerticalOptions="Center">
                                <Label Grid.Column="0" Text="Csütörtök" TextColor="White" FontAttributes="Bold" FontSize="16" VerticalOptions="Center"/>
                                <Picker Grid.Column="1" ClassId="Csütörtök" SelectedIndexChanged="OnEdzesKivalasztva" 
                                        ItemsSource="{Binding CsutortokEdzesek}" SelectedItem="{Binding KivalasztottCsutortok}" 
                                        Title="Válassz edzést..." TitleColor="LightGray" TextColor="White" VerticalOptions="Center" />
                                <Button Grid.Column="2" Clicked="OnSzerkesztesKattintva" Text="⚙️" BackgroundColor="#6200EE" TextColor="White" CornerRadius="10" Padding="0" HeightRequest="45" VerticalOptions="Center"/>
                            </Grid>
                        </Frame>
                        <BoxView HeightRequest="1" Color="#40FFFFFF" Margin="0,5"/>

                        <Frame BackgroundColor="Transparent" Padding="5" BorderColor="{Binding PentekKeret}" CornerRadius="10">
                            <Grid ColumnDefinitions="90, *, 45" ColumnSpacing="10" VerticalOptions="Center">
                                <Label Grid.Column="0" Text="Péntek" TextColor="White" FontAttributes="Bold" FontSize="18" VerticalOptions="Center"/>
                                <Picker Grid.Column="1" ClassId="Péntek" SelectedIndexChanged="OnEdzesKivalasztva" 
                                        ItemsSource="{Binding PentekEdzesek}" SelectedItem="{Binding KivalasztottPentek}" 
                                        Title="Válassz edzést..." TitleColor="LightGray" TextColor="White" VerticalOptions="Center" />
                                <Button Grid.Column="2" Clicked="OnSzerkesztesKattintva" Text="⚙️" BackgroundColor="#6200EE" TextColor="White" CornerRadius="10" Padding="0" HeightRequest="45" VerticalOptions="Center"/>
                            </Grid>
                        </Frame>
                        <BoxView HeightRequest="1" Color="#40FFFFFF" Margin="0,5"/>

                        <Frame BackgroundColor="Transparent" Padding="5" BorderColor="{Binding SzombatKeret}" CornerRadius="10">
                            <Grid ColumnDefinitions="90, *, 45" ColumnSpacing="10" VerticalOptions="Center">
                                <Label Grid.Column="0" Text="Szombat" TextColor="White" FontAttributes="Bold" FontSize="18" VerticalOptions="Center"/>
                                <Picker Grid.Column="1" ClassId="Szombat" SelectedIndexChanged="OnEdzesKivalasztva" 
                                        ItemsSource="{Binding SzombatEdzesek}" SelectedItem="{Binding KivalasztottSzombat}" 
                                        Title="Válassz edzést..." TitleColor="LightGray" TextColor="White" VerticalOptions="Center" />
                                <Button Grid.Column="2" Clicked="OnSzerkesztesKattintva" Text="⚙️" BackgroundColor="#6200EE" TextColor="White" CornerRadius="10" Padding="0" HeightRequest="45" VerticalOptions="Center"/>
                            </Grid>
                        </Frame>
                        <BoxView HeightRequest="1" Color="#40FFFFFF" Margin="0,5"/>

                        <Frame BackgroundColor="Transparent" Padding="5" BorderColor="{Binding VasarnapKeret}" CornerRadius="10">
                            <Grid ColumnDefinitions="90, *, 45" ColumnSpacing="10" VerticalOptions="Center">
                                <Label Grid.Column="0" Text="Vasárnap" TextColor="White" FontAttributes="Bold" FontSize="18" VerticalOptions="Center"/>
                                <Picker Grid.Column="1" ClassId="Vasárnap" SelectedIndexChanged="OnEdzesKivalasztva" 
                                        ItemsSource="{Binding VasarnapEdzesek}" SelectedItem="{Binding KivalasztottVasarnap}" 
                                        Title="Válassz edzést..." TitleColor="LightGray" TextColor="White" VerticalOptions="Center" />
                                <Button Grid.Column="2" Clicked="OnSzerkesztesKattintva" Text="⚙️" BackgroundColor="#6200EE" TextColor="White" CornerRadius="10" Padding="0" HeightRequest="45" VerticalOptions="Center"/>
                            </Grid>
                        </Frame>

                    </VerticalStackLayout>
                </Frame>
            </ScrollView>
        </Grid>
    </Grid>
</ContentPage>