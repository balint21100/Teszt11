<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             xmlns:local="clr-namespace:Teszt1.Frontend.Edzes"
             x:DataType="local:UjEdzesPageViewModel"
             x:Class="Teszt1.Frontend.Edzes.UjEdzesPage"
             Title="Edzés létrehozása"
             BackgroundColor="Transparent">


    <Grid>
        <Image Source="hatterkep.png" Aspect="AspectFill" HorizontalOptions="FillAndExpand" VerticalOptions="FillAndExpand"/>

        <Grid RowDefinitions="*, Auto" Padding="20">
            <ScrollView Grid.Row="0">
                <Frame BackgroundColor="#B0000000" CornerRadius="20" Padding="20" BorderColor="Gray">
                    <VerticalStackLayout Spacing="15">

                        <Label Text="Új edzés" FontSize="28" FontAttributes="Bold" TextColor="White" HorizontalOptions="Center" Margin="0,0,0,10"/>

                        <Grid ColumnDefinitions="*, *" ColumnSpacing="10" Margin="0,5">
                            <Button Grid.Column="0" 
                                    Text="Súlyemelés" 
                                    Command="{Binding TabValtasCommand}" CommandParameter="Sulyemeles"
                                    BackgroundColor="{Binding SulyemelesTabSzin}" 
                                    TextColor="White" CornerRadius="10" FontAttributes="Bold"/>

                            <Button Grid.Column="1" 
                                    Text="Egyéb Edzés" 
                                    Command="{Binding TabValtasCommand}" CommandParameter="Egyeb"
                                    BackgroundColor="{Binding EgyebTabSzin}" 
                                    TextColor="White" CornerRadius="10" FontAttributes="Bold"/>
                        </Grid>

                        <BoxView HeightRequest="1" Color="#40FFFFFF" Margin="0,5"/>

                        <VerticalStackLayout Spacing="15" IsVisible="{Binding IsSulyemelesAktiv}">
                            <VerticalStackLayout Spacing="5">
                                <Label Text="Edzés megnevezése (pl. Mell-Bicepsz)" TextColor="Gray" FontSize="14"/>
                                <Entry Text="{Binding EdzesNeve}" Placeholder="Írd be az edzés nevét..." TextColor="White" PlaceholderColor="DimGray"/>
                            </VerticalStackLayout>

                            <BoxView HeightRequest="1" Color="#20FFFFFF" />

                            <Label Text="Súlyzós gyakorlat felvétele" FontSize="18" FontAttributes="Bold" TextColor="White"/>
                            <Entry Text="{Binding GyakorlatNeve}" Placeholder="Gyakorlat neve (pl. Fekvenyomás)" TextColor="White" PlaceholderColor="DimGray"/>

                            <Grid ColumnDefinitions="*, *" ColumnSpacing="10">
                                <VerticalStackLayout Grid.Column="0" Spacing="5">
                                    <Label Text="Súly (kg)" TextColor="Gray" FontSize="12"/>
                                    <Entry Text="{Binding Suly}" Keyboard="Numeric" Placeholder="0" TextColor="White" PlaceholderColor="DimGray"/>
                                </VerticalStackLayout>
                                <VerticalStackLayout Grid.Column="1" Spacing="5">
                                    <Label Text="Ismétlés" TextColor="Gray" FontSize="12"/>
                                    <Entry Text="{Binding Ismetles}" Keyboard="Numeric" Placeholder="0" TextColor="White" PlaceholderColor="DimGray"/>
                                </VerticalStackLayout>
                            </Grid>

                            <Entry Text="{Binding SulyMegjegyzes}" Placeholder="Megjegyzés (opcionális)" TextColor="White" PlaceholderColor="DimGray"/>

                            <Button Command="{Binding SulyGyakorlatHozzaadasaCommand}"
                                    Text="Szett hozzáadása a listához" 
                                    BackgroundColor="Transparent" BorderColor="#6200EE" BorderWidth="2" TextColor="White" CornerRadius="15"/>
                        </VerticalStackLayout>

                        <VerticalStackLayout Spacing="15" IsVisible="{Binding IsEgyebAktiv}">
                            <VerticalStackLayout Spacing="5">
                                <Label Text="Edzés megnevezése (pl. Kardió nap)" TextColor="Gray" FontSize="14"/>
                                <Entry Text="{Binding EdzesNeve}" Placeholder="Írd be az edzés nevét..." TextColor="White" PlaceholderColor="DimGray"/>
                            </VerticalStackLayout>

                            <BoxView HeightRequest="1" Color="#20FFFFFF" />

                            <Label Text="Gyakorlat felvétele" FontSize="18" FontAttributes="Bold" TextColor="White"/>

                            <Entry Text="{Binding EgyebTvekenysegNeve}" Placeholder="Gyakorlat/Sport (pl. Futás)" TextColor="White" PlaceholderColor="DimGray"/>
                            <Entry Text="{Binding EgyebMegjegyzes}" Placeholder="Megjegyzés (pl. 5km, laza tempó)" TextColor="White" PlaceholderColor="DimGray"/>

                            <Button Command="{Binding EgyebGyakorlatHozzaadasaCommand}"
                                    Text="Gyakorlat hozzáadása a listához" 
                                    BackgroundColor="Transparent" BorderColor="#6200EE" BorderWidth="2" TextColor="White" CornerRadius="15"/>
                        </VerticalStackLayout>

                        <BoxView HeightRequest="1" Color="#40FFFFFF" Margin="0,10"/>

                        <Label Text="A listában szereplő gyakorlatok:" TextColor="Gray"/>
                        <CollectionView ItemsSource="{Binding FelvettGyakorlatok}" HeightRequest="200">
                            <CollectionView.ItemTemplate>
                                <DataTemplate x:DataType="x:String">
                                    <Frame BackgroundColor="#20FFFFFF" CornerRadius="10" Padding="10" Margin="0,5" BorderColor="Transparent">
                                        <Label Text="{Binding .}" TextColor="LightGray" FontSize="15"/>
                                    </Frame>
                                </DataTemplate>
                            </CollectionView.ItemTemplate>
                        </CollectionView>

                    </VerticalStackLayout>
                </Frame>
            </ScrollView>

            <Button Grid.Row="1" 
                    Command="{Binding EdzesMentesCommand}"
                    Text="Edzés mentése" 
                    BackgroundColor="#6200EE" 
                    TextColor="White" 
                    CornerRadius="25" 
                    HeightRequest="55" 
                    FontAttributes="Bold"
                    Margin="0,15,0,0"/>
        </Grid>
    </Grid>
</ContentPage>