<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             x:Class="Teszt1.Frontend.EdzesPage"
             xmlns:local="clr-namespace:Teszt1.Frontend"
             x:DataType="local:EdzesPageViewModel"
             x:Name="RootPage"
             Title="Edzés"
             BackgroundColor="Transparent">
    <Grid>
        <Image Source="hatterkep.png"
            Aspect="AspectFill"
            HorizontalOptions="FillAndExpand"
            VerticalOptions="FillAndExpand"/>
        <ScrollView>
            <VerticalStackLayout Padding="20" Spacing="15">

                <Label Text="Heti Edzésterv" FontSize="26" FontAttributes="Bold" HorizontalOptions="Center" TextColor="White" Margin="0,10" />

                <VerticalStackLayout BindableLayout.ItemsSource="{Binding WeekDays}" Spacing="10">
                    <BindableLayout.ItemTemplate>
                        <DataTemplate x:DataType="local:WorkoutDay">

                            <Frame Padding="10" CornerRadius="10">
                                <Frame.Style>
                                    <Style TargetType="Frame">
                                        <Setter Property="BackgroundColor" Value="#99000000" />
                                        <Setter Property="BorderColor" Value="Transparent" />
                                        <Style.Triggers>
                                            <DataTrigger TargetType="Frame" Binding="{Binding IsCurrentDay}" Value="True">
                                                <Setter Property="BorderColor" Value="HotPink" />
                                                <Setter Property="BackgroundColor" Value="#CC220022" />
                                            </DataTrigger>
                                        </Style.Triggers>
                                    </Style>
                                </Frame.Style>

                                <Grid ColumnDefinitions="85, *, Auto" ColumnSpacing="10" VerticalOptions="Center">

                                    <Label Grid.Column="0" Text="{Binding DayName}" FontSize="16" FontAttributes="Bold" TextColor="White" VerticalOptions="Center" />

                                    <Editor Grid.Column="1" Text="{Binding PlannedExercise}" Placeholder="Kattints ide a gépeléshez..." AutoSize="TextChanges" TextColor="White" PlaceholderColor="LightGray" VerticalOptions="Center" />

                                    <HorizontalStackLayout Grid.Column="2" Spacing="5" VerticalOptions="Center">

                                        <Button Text="✓" BackgroundColor="Green" TextColor="White" FontAttributes="Bold" CornerRadius="8" HeightRequest="40" WidthRequest="40" Padding="0"
             Command="{Binding BindingContext.SaveSingleDayCommand, Source={x:Reference RootPage}}"
             CommandParameter="{Binding .}" />

                                        <Button Text="X" BackgroundColor="Red" TextColor="White" FontAttributes="Bold" CornerRadius="8" HeightRequest="40" WidthRequest="40" Padding="0"
             Command="{Binding BindingContext.ClearDayCommand, Source={x:Reference RootPage}}"
             CommandParameter="{Binding .}" />

                                    </HorizontalStackLayout>
                                </Grid>

                            </Frame>

                        </DataTemplate>
                    </BindableLayout.ItemTemplate>
                </VerticalStackLayout>

                <Button Text="Heti terv mentése sablonként" 
                 Command="{Binding SavePlanCommand}"
                 BackgroundColor="#6200EE" TextColor="White" CornerRadius="20" HeightRequest="55" Margin="0,20" />

            </VerticalStackLayout>
        </ScrollView>
    </Grid>
</ContentPage>