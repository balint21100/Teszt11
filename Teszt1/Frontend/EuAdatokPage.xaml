<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             x:Class="Teszt1.Frontend.EuAdatokPage"
             xmlns:local="clr-namespace:Teszt1.Frontend"
             x:DataType="local:EuAdatokPageViewModel"
             Title="EÜ Adatok"
             BackgroundColor="Transparent">
    <Grid>
        <Image Source="hatterkep.png"
           Aspect="AspectFill"
           HorizontalOptions="FillAndExpand"
           VerticalOptions="FillAndExpand"/>
        <ScrollView>
            <VerticalStackLayout Padding="20" Spacing="20">

                <Label Text="EÜ adatok oldala" FontSize="24" FontAttributes="Bold" HorizontalOptions="Center" TextColor="White" />

                <Border WidthRequest="120" HeightRequest="120" StrokeShape="RoundRectangle 60" HorizontalOptions="Center" Stroke="HotPink" StrokeThickness="3">
                    <Image Source="dotnet_bot.png" Aspect="AspectFill" BackgroundColor="#333" />
                </Border>

                <Frame BackgroundColor="#99000000" BorderColor="HotPink" CornerRadius="10" Padding="15">
                    <VerticalStackLayout Spacing="10">

                        <HorizontalStackLayout Spacing="10">
                            <Label Text="Cél:" FontAttributes="Bold" TextColor="White" VerticalOptions="Center"/>
                            <Entry Text="{Binding Cel}" TextColor="White" WidthRequest="200" />
                        </HorizontalStackLayout>

                        <HorizontalStackLayout Spacing="10">
                            <Label Text="Teljesített napok a kihívásból:" TextColor="White" VerticalOptions="Center" />
                            <Label Text="{Binding KihivasProgressz}" FontAttributes="Bold" TextColor="HotPink" VerticalOptions="Center" />
                        </HorizontalStackLayout>

                        <BoxView HeightRequest="1" Color="Gray" Margin="0,10" />

                        <Grid ColumnDefinitions="120, *" RowDefinitions="Auto, Auto, Auto, Auto" RowSpacing="10">
                            <Label Grid.Row="0" Grid.Column="0" Text="Magasság (cm):" TextColor="White" VerticalOptions="Center"/>
                            <Entry Grid.Row="0" Grid.Column="1" Text="{Binding Magassag}" Keyboard="Numeric" TextColor="White"/>

                            <Label Grid.Row="1" Grid.Column="0" Text="Testsúly (kg):" TextColor="White" VerticalOptions="Center"/>
                            <Entry Grid.Row="1" Grid.Column="1" Text="{Binding Testsuly}" Keyboard="Numeric" TextColor="White"/>

                            <Label Grid.Row="2" Grid.Column="0" Text="Vérnyomás:" TextColor="White" VerticalOptions="Center"/>
                            <Entry Grid.Row="2" Grid.Column="1" Text="{Binding Vernyomas}" TextColor="White"/>

                            <Label Grid.Row="3" Grid.Column="0" Text="Lépésszám:" TextColor="White" VerticalOptions="Center"/>
                            <HorizontalStackLayout Grid.Row="3" Grid.Column="1" Spacing="5" VerticalOptions="Center">
                                <Label Text="{Binding Lepesszam}" TextColor="White" FontAttributes="Bold" />
                                <Label Text="/" TextColor="Gray" />
                                <Label Text="{Binding LepesszamCel}" TextColor="Gray" />
                            </HorizontalStackLayout>
                        </Grid>

                        <Label Text="Egyéb adat (pl. cukorbetegség, menstruáció):" TextColor="White" Margin="0,10,0,0"/>
                        <Editor Text="{Binding EgyebAdat}" TextColor="White" HeightRequest="80" BackgroundColor="#222" />

                    </VerticalStackLayout>
                </Frame>

                <Button Text="Mentés" Command="{Binding MentesCommand}" BackgroundColor="#6200EE" TextColor="White" CornerRadius="20" HeightRequest="50" />

            </VerticalStackLayout>
        </ScrollView>
    </Grid>
</ContentPage>