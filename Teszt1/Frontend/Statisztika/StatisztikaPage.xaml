<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             xmlns:local="clr-namespace:Teszt1.Frontend.Statisztika"
             x:Class="Teszt1.Frontend.Statisztika.StatisztikaPage"
             x:DataType="local:StatisztikaPageViewModel"
             Title="Statisztika"
             BackgroundColor="#121212">

    <ContentPage.BindingContext>
        <local:StatisztikaPageViewModel />
    </ContentPage.BindingContext>

    <Grid>
        <Image Source="hatterkep.png" Aspect="AspectFill" Opacity="0.5"/>

        <ScrollView Padding="15">
            <Frame BackgroundColor="#CC000000" CornerRadius="20" Padding="15" BorderColor="#444444" HasShadow="True">
                <VerticalStackLayout Spacing="20">

                    <Label Text="Elemzések" FontSize="28" FontAttributes="Bold" TextColor="White" HorizontalOptions="Center" Margin="0,10"/>

                    <!-- Fő kategória váltó -->
                    <Grid ColumnDefinitions="*, *" ColumnSpacing="10">
                        <Button Grid.Column="0" Text="Edzés" Command="{Binding TabValtasCommand}" CommandParameter="Edzes" 
                                BackgroundColor="{Binding EdzesTabSzin}" TextColor="White" CornerRadius="12" HeightRequest="50"/>
                        <Button Grid.Column="1" Text="Étkezés" Command="{Binding TabValtasCommand}" CommandParameter="Etkezes" 
                                BackgroundColor="{Binding EtkezesTabSzin}" TextColor="White" CornerRadius="12" HeightRequest="50"/>
                    </Grid>

                    <!-- Időtáv választó -->
                    <Frame BackgroundColor="#30000000" CornerRadius="15" Padding="5" BorderColor="#555555">
                        <Grid ColumnDefinitions="*,*,*,*">
                            <Button Grid.Column="0" Text="Heti" Command="{Binding IdotavValtasCommand}" CommandParameter="Heti" BackgroundColor="{Binding HetiSzin}" TextColor="White" CornerRadius="10" FontSize="11" HeightRequest="35"/>
                            <Button Grid.Column="1" Text="Havi" Command="{Binding IdotavValtasCommand}" CommandParameter="Havi" BackgroundColor="{Binding HaviSzin}" TextColor="White" CornerRadius="10" FontSize="11" HeightRequest="35"/>
                            <Button Grid.Column="2" Text="Éves" Command="{Binding IdotavValtasCommand}" CommandParameter="Eves" BackgroundColor="{Binding EvesSzin}" TextColor="White" CornerRadius="10" FontSize="11" HeightRequest="35"/>
                            <Button Grid.Column="3" Text="Egyéni" Command="{Binding IdotavValtasCommand}" CommandParameter="Egyeni" BackgroundColor="{Binding EgyeniSzin}" TextColor="White" CornerRadius="10" FontSize="11" HeightRequest="35"/>
                        </Grid>
                    </Frame>

                    <!-- Szűrők -->
                    <Frame BackgroundColor="#20FFFFFF" CornerRadius="15" Padding="15" BorderColor="Transparent">
                        <VerticalStackLayout Spacing="10">
                            <Picker IsVisible="{Binding IsHetiLathato}" ItemsSource="{Binding Hetek}" SelectedItem="{Binding KivalasztottHet}" TextColor="White" Title="Válassz hetet..." HorizontalOptions="Fill"/>
                            <Picker IsVisible="{Binding IsHaviLathato}" ItemsSource="{Binding Honapok}" SelectedItem="{Binding KivalasztottHonap}" TextColor="White" Title="Válassz hónapot..." HorizontalOptions="Fill"/>
                            <Picker IsVisible="{Binding IsEvesLathato}" ItemsSource="{Binding Evek}" SelectedItem="{Binding KivalasztottEv}" TextColor="White" Title="Válassz évet..." HorizontalOptions="Fill"/>

                            <Grid IsVisible="{Binding IsEgyeniLathato}" ColumnDefinitions="*, Auto, *" ColumnSpacing="5">
                                <DatePicker Grid.Column="0" Date="{Binding KezdoDatum}" TextColor="White" Format="yyyy.MM.dd." FontSize="12"/>
                                <Label Grid.Column="1" Text="-" TextColor="White" VerticalOptions="Center"/>
                                <DatePicker Grid.Column="2" Date="{Binding VegDatum}" TextColor="White" Format="yyyy.MM.dd." FontSize="12"/>
                            </Grid>
                        </VerticalStackLayout>
                    </Frame>

                    <!-- Összesítő kártyák -->
                    <Grid ColumnDefinitions="*,*" ColumnSpacing="10">
                        <Frame Grid.Column="0" BackgroundColor="#20FFFFFF" CornerRadius="15" Padding="12">
                            <VerticalStackLayout>
                                <Label Text="{Binding OsszesitoCimke1}" TextColor="LightGray" FontSize="11"/>
                                <Label Text="{Binding OsszesitoErtek1}" TextColor="White" FontSize="16" FontAttributes="Bold"/>
                            </VerticalStackLayout>
                        </Frame>
                        <Frame Grid.Column="1" BackgroundColor="#20FFFFFF" CornerRadius="15" Padding="12">
                            <VerticalStackLayout>
                                <Label Text="{Binding OsszesitoCimke2}" TextColor="LightGray" FontSize="11"/>
                                <Label Text="{Binding OsszesitoErtek2}" TextColor="White" FontSize="16" FontAttributes="Bold"/>
                            </VerticalStackLayout>
                        </Frame>
                    </Grid>

                    <!-- Grafikon részleg -->
                    <Frame BackgroundColor="#20FFFFFF" CornerRadius="15" Padding="15">
                        <VerticalStackLayout Spacing="10">
                            <Label Text="{Binding AktualisCim}" TextColor="White" FontSize="16" FontAttributes="Bold" HorizontalOptions="Center"/>

                            <Grid ColumnDefinitions="40, *" HeightRequest="180">
                                <!-- Y tengely -->
                                <VerticalStackLayout Grid.Column="0" VerticalOptions="FillAndExpand" Spacing="0">
                                    <Label Text="{Binding YMaxSzoveg}" TextColor="Gray" FontSize="10" VerticalOptions="Start"/>
                                    <BoxView VerticalOptions="CenterAndExpand" Color="Transparent"/>
                                    <Label Text="{Binding YMidSzoveg}" TextColor="Gray" FontSize="10" VerticalOptions="Center"/>
                                    <BoxView VerticalOptions="CenterAndExpand" Color="Transparent"/>
                                    <Label Text="0" TextColor="Gray" FontSize="10" VerticalOptions="End" Margin="0,0,0,15"/>
                                </VerticalStackLayout>

                                <!-- Oszlopok -->
                                <ScrollView Grid.Column="1" Orientation="Horizontal" HorizontalScrollBarVisibility="Never">
                                    <HorizontalStackLayout BindableLayout.ItemsSource="{Binding GrafikonOszlopok}" Spacing="10" VerticalOptions="End" HeightRequest="180">
                                        <BindableLayout.ItemTemplate>
                                            <DataTemplate x:DataType="local:GrafikonOszlop">
                                                <VerticalStackLayout VerticalOptions="End" Spacing="5" WidthRequest="30">
                                                    <BoxView WidthRequest="20" HeightRequest="{Binding Magassag}" Color="{Binding Szin}" CornerRadius="4" HorizontalOptions="Center"/>
                                                    <Label Text="{Binding Cimke}" TextColor="White" FontSize="9" HorizontalOptions="Center"/>
                                                </VerticalStackLayout>
                                            </DataTemplate>
                                        </BindableLayout.ItemTemplate>
                                    </HorizontalStackLayout>
                                </ScrollView>
                            </Grid>
                        </VerticalStackLayout>
                    </Frame>

                    <!-- Top Lista -->
                    <Label Text="{Binding TopListaCim}" FontSize="20" FontAttributes="Bold" TextColor="White" Margin="5,10,0,0"/>
                    <CollectionView ItemsSource="{Binding TopLista}" HeightRequest="350">
                        <CollectionView.ItemTemplate>
                            <DataTemplate x:DataType="local:TopListaElem">
                                <Frame BackgroundColor="{Binding HatterSzin}" CornerRadius="12" Padding="15,10" Margin="0,0,0,10" BorderColor="Transparent">
                                    <Grid ColumnDefinitions="35, *, Auto">
                                        <Label Grid.Column="0" Text="{Binding HelyezesText}" TextColor="{Binding SzovegSzin}" FontAttributes="Bold" VerticalOptions="Center"/>
                                        <Label Grid.Column="1" Text="{Binding Nev}" TextColor="{Binding SzovegSzin}" FontAttributes="Bold" VerticalOptions="Center"/>
                                        <Label Grid.Column="2" Text="{Binding ErtekSzoveg}" TextColor="{Binding SzovegSzin}" VerticalOptions="Center"/>
                                    </Grid>
                                </Frame>
                            </DataTemplate>
                        </CollectionView.ItemTemplate>
                    </CollectionView>

                </VerticalStackLayout>
            </Frame>
        </ScrollView>
    </Grid>
</ContentPage>