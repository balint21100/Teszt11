<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             xmlns:local="clr-namespace:Teszt1.Frontend.Statisztika"
             x:Class="Teszt1.Frontend.Statisztika.StatisztikaPage"
             x:DataType="local:StatisztikaPageViewModel"
             Title="Statisztika"
             BackgroundColor="Transparent">

    <ContentPage.BindingContext>
        <local:StatisztikaPageViewModel />
    </ContentPage.BindingContext>
    <Grid>
        <Image Source="hatterkep.png" Aspect="AspectFill" HorizontalOptions="FillAndExpand" VerticalOptions="FillAndExpand"/>

        <ScrollView Padding="20">
            <Frame BackgroundColor="#B0000000" CornerRadius="20" Padding="20" BorderColor="Gray">
                <VerticalStackLayout Spacing="15">

                    <Label Text="Elemzések" FontSize="28" FontAttributes="Bold" TextColor="White" HorizontalOptions="Center" Margin="0,0,0,10"/>

                    <Grid ColumnDefinitions="*, *" ColumnSpacing="10">
                        <Button Grid.Column="0" Text="Edzés" Command="{Binding TabValatasCommand}" CommandParameter="Edzes" BackgroundColor="{Binding EdzesTabSzin}" TextColor="White" CornerRadius="15" FontAttributes="Bold" HeightRequest="45"/>
                        <Button Grid.Column="1" Text="Étkezés" Command="{Binding TabValtasCommand}" CommandParameter="Etkezes" BackgroundColor="{Binding EtkezesTabSzin}" TextColor="White" CornerRadius="15" FontAttributes="Bold" HeightRequest="45"/>
                    </Grid>

                    <Frame BackgroundColor="#40000000" CornerRadius="15" Padding="5" BorderColor="Transparent">
                        <Grid ColumnDefinitions="*,*,*,*">
                            <Button Grid.Column="0" Text="Heti" Command="{Binding IdotavValtasCommand}" CommandParameter="Heti" BackgroundColor="{Binding HetiSzin}" TextColor="White" CornerRadius="12" FontAttributes="Bold" FontSize="12" Padding="0" HeightRequest="35"/>
                            <Button Grid.Column="1" Text="Havi" Command="{Binding IdotavValtasCommand}" CommandParameter="Havi" BackgroundColor="{Binding HaviSzin}" TextColor="White" CornerRadius="12" FontAttributes="Bold" FontSize="12" Padding="0" HeightRequest="35"/>
                            <Button Grid.Column="2" Text="Éves" Command="{Binding IdotavValtasCommand}" CommandParameter="Eves" BackgroundColor="{Binding EvesSzin}" TextColor="White" CornerRadius="12" FontAttributes="Bold" FontSize="12" Padding="0" HeightRequest="35"/>
                            <Button Grid.Column="3" Text="Egyéni" Command="{Binding IdotavValtasCommand}" CommandParameter="Egyeni" BackgroundColor="{Binding EgyeniSzin}" TextColor="White" CornerRadius="12" FontAttributes="Bold" FontSize="12" Padding="0" HeightRequest="35"/>
                        </Grid>
                    </Frame>

                    <Frame BackgroundColor="#20FFFFFF" CornerRadius="15" Padding="15" BorderColor="Transparent">
                        <VerticalStackLayout Spacing="10">

                            <Picker IsVisible="{Binding IsHetiLathato}" ItemsSource="{Binding Hetek}" SelectedItem="{Binding KivalasztottHet}" SelectedIndexChanged="AdatokFrissitese_Kivalasztva" TextColor="White" Title="Válassz hetet..." TitleColor="LightGray" HorizontalOptions="Center" WidthRequest="250"/>
                            <Picker IsVisible="{Binding IsHaviLathato}" ItemsSource="{Binding Honapok}" SelectedItem="{Binding KivalasztottHonap}" SelectedIndexChanged="AdatokFrissitese_Kivalasztva" TextColor="White" Title="Válassz hónapot..." TitleColor="LightGray" HorizontalOptions="Center" WidthRequest="250"/>
                            <Picker IsVisible="{Binding IsEvesLathato}" ItemsSource="{Binding Evek}" SelectedItem="{Binding KivalasztottEv}" SelectedIndexChanged="AdatokFrissitese_Kivalasztva" TextColor="White" Title="Válassz évet..." TitleColor="LightGray" HorizontalOptions="Center" WidthRequest="250"/>

                            <Grid IsVisible="{Binding IsEgyeniLathato}" ColumnDefinitions="*, Auto, *" ColumnSpacing="10" VerticalOptions="Center">
                                <DatePicker Grid.Column="0" Date="{Binding KezdoDatum}" TextColor="White" Format="yyyy. MM. dd." HorizontalOptions="Center" FontSize="13"/>
                                <Label Grid.Column="1" Text="-" TextColor="White" VerticalOptions="Center" FontAttributes="Bold"/>
                                <DatePicker Grid.Column="2" Date="{Binding VegDatum}" TextColor="White" Format="yyyy. MM. dd." HorizontalOptions="Center" FontSize="13"/>
                            </Grid>

                            <Button IsVisible="{Binding IsEgyeniLathato}" 
                                Command="{Binding FrissitsAdatokatCommand}" 
                                Text="Adatok lekérdezése" 
                                BackgroundColor="#6200EE" 
                                TextColor="White" 
                                CornerRadius="15" 
                                FontAttributes="Bold"
                                Margin="0,5,0,0" 
                                HeightRequest="45"/>

                        </VerticalStackLayout>
                    </Frame>

                    <Grid ColumnDefinitions="*,*" ColumnSpacing="10">
                        <Frame Grid.Column="0" BackgroundColor="#20FFFFFF" CornerRadius="15" Padding="15" BorderColor="Transparent">
                            <VerticalStackLayout Spacing="5">
                                <Label Text="{Binding OsszesitoCimke1}" TextColor="LightGray" FontSize="12"/>
                                <Label Text="{Binding OsszesitoErtek1}" TextColor="White" FontSize="18" FontAttributes="Bold"/>
                            </VerticalStackLayout>
                        </Frame>
                        <Frame Grid.Column="1" BackgroundColor="#20FFFFFF" CornerRadius="15" Padding="15" BorderColor="Transparent">
                            <VerticalStackLayout Spacing="5">
                                <Label Text="{Binding OsszesitoCimke2}" TextColor="LightGray" FontSize="12"/>
                                <Label Text="{Binding OsszesitoErtek2}" TextColor="White" FontSize="18" FontAttributes="Bold"/>
                            </VerticalStackLayout>
                        </Frame>
                    </Grid>

                    <Frame BackgroundColor="#20FFFFFF" CornerRadius="15" Padding="15" BorderColor="Transparent">
                        <VerticalStackLayout Spacing="15">
                            <Label Text="{Binding AktualisCim}" TextColor="White" FontSize="16" FontAttributes="Bold" HorizontalOptions="Center"/>

                            <Grid ColumnDefinitions="45, *" HeightRequest="200" Margin="0,10,0,0">
                                <Grid Grid.Column="0" RowDefinitions="*,*,*">
                                    <Label Text="{Binding YMaxSzoveg}" TextColor="LightGray" FontSize="10" VerticalOptions="Start" HorizontalOptions="End" Margin="0,0,5,0"/>
                                    <Label Text="{Binding YMidSzoveg}" TextColor="LightGray" FontSize="10" VerticalOptions="Center" HorizontalOptions="End" Margin="0,0,5,0"/>
                                    <Label Text="0" TextColor="LightGray" FontSize="10" VerticalOptions="End" HorizontalOptions="End" Margin="0,0,5,15"/>
                                </Grid>

                                <Grid Grid.Column="1" RowDefinitions="*,*,*">
                                    <BoxView HeightRequest="1" Color="#30FFFFFF" VerticalOptions="Start"/>
                                    <BoxView HeightRequest="1" Color="#30FFFFFF" VerticalOptions="Center"/>
                                    <BoxView HeightRequest="1" Color="#30FFFFFF" VerticalOptions="End" Margin="0,0,0,15"/>
                                </Grid>

                                <HorizontalStackLayout Grid.Column="1" BindableLayout.ItemsSource="{Binding GrafikonOszlopok}" Spacing="8" HorizontalOptions="Center" VerticalOptions="End" HeightRequest="200">
                                    <BindableLayout.ItemTemplate>
                                        <DataTemplate>
                                            <VerticalStackLayout VerticalOptions="End" Spacing="5" WidthRequest="25">
                                                <BoxView WidthRequest="20" HeightRequest="{Binding Magassag}" Color="{Binding Szin}" CornerRadius="3" HorizontalOptions="Center"/>
                                                <Label Text="{Binding Cimke}" TextColor="LightGray" FontSize="10" HorizontalOptions="Center" MaxLines="1"/>
                                            </VerticalStackLayout>
                                        </DataTemplate>
                                    </BindableLayout.ItemTemplate>
                                </HorizontalStackLayout>
                            </Grid>
                        </VerticalStackLayout>
                    </Frame>

                    <Label Text="{Binding TopListaCim}" FontSize="20" FontAttributes="Bold" TextColor="White" Margin="0,10,0,5"/>

                    <VerticalStackLayout BindableLayout.ItemsSource="{Binding TopLista}" Spacing="8">
                        <BindableLayout.ItemTemplate>
                            <DataTemplate>
                                <Frame BackgroundColor="{Binding HatterSzin}" CornerRadius="12" Padding="15,10" BorderColor="Transparent">
                                    <Grid ColumnDefinitions="30, *, Auto">
                                        <Label Grid.Column="0" Text="{Binding HelyezesText}" TextColor="{Binding SzovegSzin}" FontAttributes="Bold" FontSize="16" VerticalOptions="Center"/>
                                        <Label Grid.Column="1" Text="{Binding Nev}" TextColor="{Binding SzovegSzin}" FontAttributes="Bold" FontSize="15" VerticalOptions="Center"/>
                                        <Label Grid.Column="2" Text="{Binding ErtekSzoveg}" TextColor="{Binding SzovegSzin}" FontSize="12" VerticalOptions="Center" HorizontalTextAlignment="End"/>
                                    </Grid>
                                </Frame>
                            </DataTemplate>
                        </BindableLayout.ItemTemplate>
                    </VerticalStackLayout>

                </VerticalStackLayout>
            </Frame>
        </ScrollView>
    </Grid>
</ContentPage>