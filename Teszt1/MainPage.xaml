<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             xmlns:local="clr-namespace:Teszt1.Frontend"
             x:Class="Teszt1.MainPage"
             x:DataType="local:MainPageViewModel"
             BackgroundColor="Transparent"
             Title="Home">

    <Grid>
        <Image Source="hatterkep.png"
           Aspect="AspectFill"
           HorizontalOptions="FillAndExpand"
           VerticalOptions="FillAndExpand"/>
        <ScrollView>
            <VerticalStackLayout Padding="20" Spacing="20">

                <Label Text="Étkezések rögzítése" FontSize="26" FontAttributes="Bold" HorizontalOptions="Center" TextColor="White" />

                <VerticalStackLayout Spacing="5">
                    <Label Text="{Binding CalorieText}" FontAttributes="Bold" FontSize="18" TextColor="White" />
                    <ProgressBar Progress="{Binding CalorieProgress}" ProgressColor="DodgerBlue" HeightRequest="12" />
                </VerticalStackLayout>

                <VerticalStackLayout Spacing="15">
                    <VerticalStackLayout Spacing="2">
                        <Label Text="{Binding CarbsText}" FontSize="12" TextColor="White" />
                        <ProgressBar Progress="{Binding CarbsProgress}" ProgressColor="Red" HeightRequest="8" />
                    </VerticalStackLayout>

                    <VerticalStackLayout Spacing="2">
                        <Label Text="{Binding ProteinText}" FontSize="12" TextColor="White" />
                        <ProgressBar Progress="{Binding ProteinProgress}" ProgressColor="Green" HeightRequest="8" />
                    </VerticalStackLayout>

                    <VerticalStackLayout Spacing="2">
                        <Label Text="{Binding FatText}" FontSize="12" TextColor="White" />
                        <ProgressBar Progress="{Binding FatProgress}" ProgressColor="Orange" HeightRequest="8" />
                    </VerticalStackLayout>
                </VerticalStackLayout>

                <Button Text="Étkezés hozzáadása" 
                Command="{Binding GoToEtkezesCommand}"
                BackgroundColor="#6200EE" 
                TextColor="White" 
                CornerRadius="20"
                HeightRequest="55" />

                <Label Text="Utolsó 3 étkezés:" FontSize="18" FontAttributes="Bold" TextColor="White" />

                <CollectionView ItemsSource="{Binding RecentMeals}">
                    <CollectionView.ItemTemplate>
                        <DataTemplate x:DataType="x:String">
                            <Label Text="{Binding .}" TextColor="White" FontSize="14" Margin="0,5"/>
                        </DataTemplate>
                    </CollectionView.ItemTemplate>
                </CollectionView>

            </VerticalStackLayout>
        </ScrollView>
    </Grid>
</ContentPage>